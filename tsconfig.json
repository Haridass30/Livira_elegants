{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true
  },
  "include": [".astro/types.d.ts", "src"],
  "exclude": ["dist", "node_modules", "functions"]
}
