---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { site } from "../config";
import { getSiteContent } from "../lib/siteContent";
import heroImg from "../assets/hero.jpg";

const { slides } = await getSiteContent();
const multiple = slides.length > 1;

const all = await getCollection("products");
// Shop-by tiles use top-level "main" categories (managed from /admin/collections):
// a direct main that has products, or a group main with at least one populated
// sub-category. Falls back to distinct product categories if the tree is empty.
const cats = (await getCollection("categories")).map((c) => c.data);
const productLeaves = new Set(all.map((p) => p.data.category));
const mainCategories = cats
  .filter((c) => !c.parent)
  .sort((a, b) => a.position - b.position)
  .filter((m) =>
    m.kind === "group"
      ? cats.some((s) => s.parent === m.name && productLeaves.has(s.name))
      : productLeaves.has(m.name),
  )
  .map((m) => m.name);
const categories = mainCategories.length
  ? mainCategories
  : [...productLeaves].sort();
const featured = all.filter((p) => p.data.featured).slice(0, 3);
// Top up to 3 if not enough are flagged featured.
const featuredGrid =
  featured.length >= 3 ? featured : [...featured, ...all].slice(0, 3);

// Brand value props for the trust strip (line-icon medallions).
const values = [
  {
    title: "Handcrafted",
    desc: "Made in small batches by hand in India.",
    svg: `<path d="M12 3 4 9l8 12 8-12-8-6Z" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M4 9h16M9 3l-2 6 5 12M15 3l2 6-5 12" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>`,
  },
  {
    title: "Hallmarked metals",
    desc: "Recycled gold & sterling silver, certified.",
    svg: `<circle cx="12" cy="10" r="6" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M12 7.2l1 2 2.2.2-1.6 1.5.5 2.1L12 12l-2 1.1.5-2.1L8.8 9.4 11 9.2l1-2Z" fill="currentColor"/><path d="M9 15.5 8 22l4-2 4 2-1-6.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>`,
  },
  {
    title: "14-day returns",
    desc: "Easy returns on unworn pieces.",
    svg: `<path d="M4 12a8 8 0 1 1 2.5 5.8" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M4 8v4h4" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.name,
  description: site.statement,
  url: Astro.site?.href,
};
---

<BaseLayout
  title={site.name}
  description={site.statement}
  padTop={false}
  jsonLd={jsonLd}
>
  <!-- Hero banner slider (one or more admin-editable banners) -->
  <section
    class="hero-slider relative h-[88svh] min-h-[560px] overflow-hidden"
    aria-roledescription="carousel"
    aria-label="Featured banners"
    data-has-hero
  >
    <div class="hero-track flex h-full w-full" id="hero-track">
      {
        slides.map((slide, i) => (
          <div
            class="hero-slide relative flex h-full w-full flex-shrink-0 items-end"
            aria-roledescription="slide"
            aria-label={`Banner ${i + 1} of ${slides.length}`}
          >
            {slide.image ? (
              <img
                src={slide.image.url}
                alt={slide.heading}
                width={slide.image.width}
                height={slide.image.height}
                loading={i === 0 ? "eager" : "lazy"}
                fetchpriority={i === 0 ? "high" : "auto"}
                class="absolute inset-0 h-full w-full object-cover"
              />
            ) : (
              <Image
                src={heroImg}
                alt={slide.heading}
                widths={[640, 1024, 1600, 2400]}
                sizes="100vw"
                loading={i === 0 ? "eager" : "lazy"}
                fetchpriority={i === 0 ? "high" : undefined}
                class="absolute inset-0 h-full w-full object-cover"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[#150b10]/85 via-[#150b10]/30 to-[#150b10]/50" />
            <div class="container-page relative pb-16 md:pb-24">
              <div class="hero-copy">
                <p class="eyebrow flex items-center gap-2">
                  <span class="gem-mark">◆</span> Fine jewellery · India
                </p>
                <h1 class="mt-4 max-w-2xl font-serif text-4xl leading-[1.08] md:text-6xl">
                  <span class="text-metallic is-animated">{slide.heading}</span>
                </h1>
                {slide.subtext && (
                  <p class="mt-5 max-w-md text-charcoal/85">{slide.subtext}</p>
                )}
                <div class="mt-8 flex flex-wrap gap-4">
                  <a href={slide.buttonLink} class="btn btn-primary">
                    {slide.buttonLabel}
                  </a>
                  {slide.secondaryLabel && (
                    <a href={slide.secondaryLink} class="btn btn-outline">
                      {slide.secondaryLabel}
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Inset gold frame — a quiet luxury border over the hero. -->
    <div class="pointer-events-none absolute inset-3 z-[5] border hairline md:inset-6"></div>

    {
      multiple && (
        <>
          <button type="button" class="hero-arrow hero-prev" aria-label="Previous banner">
            ‹
          </button>
          <button type="button" class="hero-arrow hero-next" aria-label="Next banner">
            ›
          </button>
          <div class="hero-dots" aria-label="Choose banner">
            {slides.map((_, i) => (
              <button
                type="button"
                class="hero-dot"
                data-dot={i}
                aria-label={`Go to banner ${i + 1}`}
              />
            ))}
          </div>
        </>
      )
    }
  </section>

  <!-- Brand statement -->
  <section class="container-page py-24 text-center md:py-32">
    <p class="eyebrow">The Livira way</p>
    <p
      class="mx-auto mt-6 max-w-3xl font-serif text-2xl leading-relaxed text-charcoal md:text-[2rem]"
    >
      {site.statement}
    </p>
    <div class="divider-gem mt-10" aria-hidden="true">◆</div>
  </section>

  <!-- Featured grid -->
  <section class="container-page">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <p class="eyebrow flex items-center gap-2">
          <span class="gem-mark">◆</span> Curated
        </p>
        <h2 class="mt-2 font-serif text-3xl md:text-4xl">Pieces we love</h2>
      </div>
      <a href="/shop" class="link-underline hidden text-sm uppercase tracking-[0.14em] md:inline"
        >View all</a
      >
    </div>
    <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 md:gap-x-8">
      {featuredGrid.map((entry, i) => <ProductCard entry={entry} priority={i < 3} />)}
    </div>
    <div class="mt-10 text-center md:hidden">
      <a href="/shop" class="btn btn-outline">View all</a>
    </div>
  </section>

  <!-- Categories -->
  <section class="container-page py-24 md:py-32">
    <div class="mb-12 text-center">
      <p class="eyebrow flex items-center justify-center gap-2">
        <span class="gem-mark">◆</span> Shop by
      </p>
      <h2 class="mt-3 font-serif text-3xl md:text-4xl">Collections</h2>
      <div class="divider-gem mt-5" aria-hidden="true">◆</div>
    </div>
    <div class="cat-grid">
      {
        categories.map((cat) => (
          <a
            href={`/shop?category=${encodeURIComponent(cat)}`}
            class="card-lux group flex aspect-square flex-col items-center justify-center gap-3 overflow-hidden rounded-[3px] px-3 text-center"
          >
            <span class="gem-mark opacity-60 transition-opacity group-hover:opacity-100">◆</span>
            <span class="font-serif text-xl leading-tight tracking-wide md:text-2xl">{cat}</span>
            <span class="gold-rule w-8 transition-all duration-500 group-hover:w-16" />
            <span class="text-[10px] uppercase tracking-[0.18em] text-champagne/70 transition-colors group-hover:text-champagne-soft">
              Explore →
            </span>
          </a>
        ))
      }
      <a
        href={`/shop?category=${encodeURIComponent("Anti-Tarnish Jewels")}`}
        class="card-lux group flex aspect-square flex-col items-center justify-center gap-3 overflow-hidden rounded-[3px] px-3 text-center"
      >
        <span class="gem-mark opacity-60 transition-opacity group-hover:opacity-100">◆</span>
        <span class="font-serif text-lg leading-tight tracking-wide md:text-xl">
          Anti-Tarnish<br />Jewels
        </span>
        <span class="gold-rule w-8 transition-all duration-500 group-hover:w-16" />
        <span class="text-[10px] uppercase tracking-[0.18em] text-champagne/70 transition-colors group-hover:text-champagne-soft">
          Explore →
        </span>
      </a>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y hairline bg-bone/40">
    <div class="container-page grid gap-10 py-16 text-center md:grid-cols-3">
      {
        values.map((v) => (
          <div class="flex flex-col items-center">
            <span class="icon-medallion" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" set:html={v.svg} />
            </span>
            <h3 class="mt-5 font-serif text-xl">{v.title}</h3>
            <p class="mx-auto mt-2 max-w-xs text-sm text-charcoal/65">{v.desc}</p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  /* Collections tiles: two-up on mobile, one flexible row on wider screens
     (so extra tiles like "Anti-Tarnish Jewels" sit beside the others). */
  .cat-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  @media (min-width: 768px) {
    .cat-grid {
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    }
  }

  /* Sliding banner carousel — the track shifts one full width per slide. */
  .hero-track {
    transition: transform 0.7s var(--ease-soft);
    will-change: transform;
  }

  /* Text reveals only for the slide currently on screen. */
  .hero-copy > * {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.7s var(--ease-soft),
      transform 0.7s var(--ease-soft);
  }
  .hero-slide.is-active .hero-copy > * {
    opacity: 1;
    transform: none;
  }
  .hero-copy > *:nth-child(2) {
    transition-delay: 0.08s;
  }
  .hero-copy > *:nth-child(3) {
    transition-delay: 0.16s;
  }
  .hero-copy > *:nth-child(4) {
    transition-delay: 0.24s;
  }

  .hero-arrow {
    position: absolute;
    top: 50%;
    z-index: 10;
    transform: translateY(-50%);
    display: flex;
    height: 46px;
    width: 46px;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--color-champagne) 32%, transparent);
    border-radius: 999px;
    background: rgba(21, 11, 16, 0.32);
    color: var(--color-champagne-soft);
    font-size: 24px;
    line-height: 1;
    backdrop-filter: blur(4px);
    cursor: pointer;
    transition:
      background-color 0.3s var(--ease-soft),
      color 0.3s var(--ease-soft);
  }
  .hero-arrow:hover {
    background: var(--color-champagne);
    color: #241318;
  }
  .hero-prev {
    left: 16px;
  }
  .hero-next {
    right: 16px;
  }
  @media (max-width: 767px) {
    .hero-arrow {
      display: none;
    }
  }

  .hero-dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    z-index: 10;
    display: flex;
    transform: translateX(-50%);
    gap: 10px;
  }
  .hero-dot {
    height: 9px;
    width: 9px;
    border: 0;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-champagne-soft) 34%, transparent);
    cursor: pointer;
    transition:
      width 0.3s var(--ease-soft),
      background-color 0.3s var(--ease-soft);
  }
  .hero-dot.is-active {
    width: 26px;
    background: var(--color-champagne-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-track {
      transition: none;
    }
    .hero-copy > * {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Auto-advancing banner carousel. Falls back to a static first slide when
  // there is only one banner or the visitor prefers reduced motion.
  const root = document.querySelector<HTMLElement>(".hero-slider");
  if (root) {
    const track = root.querySelector<HTMLElement>(".hero-track");
    const slides = [...root.querySelectorAll<HTMLElement>(".hero-slide")];
    const dots = [...root.querySelectorAll<HTMLElement>(".hero-dot")];
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      if (track) track.style.transform = `translateX(-${i * 100}%)`;
      slides.forEach((s, k) => s.classList.toggle("is-active", k === i));
      dots.forEach((d, k) => d.classList.toggle("is-active", k === i));
    };

    const stop = () => {
      if (timer) clearInterval(timer);
      timer = undefined;
    };
    const start = () => {
      if (reduce || slides.length < 2) return;
      stop();
      timer = setInterval(() => show(i + 1), 6000);
    };

    root.querySelector(".hero-next")?.addEventListener("click", () => {
      show(i + 1);
      start();
    });
    root.querySelector(".hero-prev")?.addEventListener("click", () => {
      show(i - 1);
      start();
    });
    dots.forEach((d, k) =>
      d.addEventListener("click", () => {
        show(k);
        start();
      }),
    );
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);

    show(0);
    start();
  }
</script>
