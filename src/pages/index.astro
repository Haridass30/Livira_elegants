---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { site } from "../config";
import { getSiteContent } from "../lib/siteContent";
import heroImg from "../assets/hero.jpg";

const { hero } = await getSiteContent();

const all = await getCollection("products");
// Collections present in the catalogue (managed from /admin/collections).
const categories = [...new Set(all.map((p) => p.data.category))].sort();
const featured = all.filter((p) => p.data.featured).slice(0, 3);
// Top up to 3 if not enough are flagged featured.
const featuredGrid =
  featured.length >= 3 ? featured : [...featured, ...all].slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.name,
  description: site.statement,
  url: Astro.site?.href,
};
---

<BaseLayout
  title={site.name}
  description={site.statement}
  padTop={false}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section
    data-has-hero
    class="relative flex h-[88svh] min-h-[560px] items-end overflow-hidden"
  >
    {
      hero.image ? (
        <img
          src={hero.image.url}
          alt={hero.heading}
          width={hero.image.width}
          height={hero.image.height}
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 h-full w-full object-cover"
        />
      ) : (
        <Image
          src={heroImg}
          alt={hero.heading}
          widths={[640, 1024, 1600, 2400]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 h-full w-full object-cover"
        />
      )
    }
    <div
      class="absolute inset-0 bg-gradient-to-t from-[#150b10]/85 via-[#150b10]/30 to-[#150b10]/50"
    >
    </div>
    <div class="container-page relative pb-16 md:pb-24">
      <p class="eyebrow reveal reveal-1">Fine jewellery · India</p>
      <h1
        class="reveal reveal-2 mt-4 max-w-2xl font-serif text-4xl leading-[1.08] md:text-6xl"
      >
        <span class="text-metallic">{hero.heading}</span>
      </h1>
      {
        hero.subtext && (
          <p class="reveal reveal-3 mt-5 max-w-md text-charcoal/85">{hero.subtext}</p>
        )
      }
      <div class="reveal reveal-3 mt-8 flex flex-wrap gap-4">
        <a href={hero.buttonLink} class="btn btn-primary">{hero.buttonLabel}</a>
        {
          hero.secondaryLabel && (
            <a href={hero.secondaryLink} class="btn btn-outline">
              {hero.secondaryLabel}
            </a>
          )
        }
      </div>
    </div>
  </section>

  <!-- Brand statement -->
  <section class="container-page py-24 text-center md:py-32">
    <p class="eyebrow">The Livira way</p>
    <p
      class="mx-auto mt-6 max-w-3xl font-serif text-2xl leading-relaxed text-charcoal md:text-[2rem]"
    >
      {site.statement}
    </p>
    <div class="divider-gem mt-10" aria-hidden="true">◆</div>
  </section>

  <!-- Featured grid -->
  <section class="container-page">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <p class="eyebrow">Curated</p>
        <h2 class="mt-2 font-serif text-3xl md:text-4xl">Pieces we love</h2>
      </div>
      <a href="/shop" class="link-underline hidden text-sm uppercase tracking-[0.14em] md:inline"
        >View all</a
      >
    </div>
    <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 md:gap-x-8">
      {featuredGrid.map((entry, i) => <ProductCard entry={entry} priority={i < 3} />)}
    </div>
    <div class="mt-10 text-center md:hidden">
      <a href="/shop" class="btn btn-outline">View all</a>
    </div>
  </section>

  <!-- Categories -->
  <section class="container-page py-24 md:py-32">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {
        categories.map((cat) => (
          <a
            href={`/shop?category=${encodeURIComponent(cat)}`}
            class="group relative flex aspect-square items-center justify-center border hairline bg-bone/50 transition-colors hover:bg-bone"
          >
            <span class="font-serif text-xl tracking-wide md:text-2xl">{cat}</span>
            <span class="absolute bottom-4 text-[11px] uppercase tracking-[0.16em] text-champagne opacity-0 transition-opacity group-hover:opacity-100">
              Explore →
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y hairline bg-bone/50">
    <div class="container-page grid gap-8 py-14 text-center md:grid-cols-3">
      {
        [
          ["Handcrafted", "Made in small batches by hand in India."],
          ["Hallmarked metals", "Recycled gold & sterling silver, certified."],
          ["14-day returns", "Easy returns on unworn pieces."],
        ].map(([t, d]) => (
          <div>
            <h3 class="font-serif text-xl">{t}</h3>
            <p class="mx-auto mt-2 max-w-xs text-sm text-charcoal/65">{d}</p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
