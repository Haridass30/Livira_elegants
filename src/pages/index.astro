---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { site } from "../config";
import { getSiteContent } from "../lib/siteContent";
import heroImg from "../assets/hero.jpg";

const { slides } = await getSiteContent();
const multiple = slides.length > 1;

const all = await getCollection("products");
// Collections present in the catalogue (managed from /admin/collections).
const categories = [...new Set(all.map((p) => p.data.category))].sort();
const featured = all.filter((p) => p.data.featured).slice(0, 3);
// Top up to 3 if not enough are flagged featured.
const featuredGrid =
  featured.length >= 3 ? featured : [...featured, ...all].slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.name,
  description: site.statement,
  url: Astro.site?.href,
};
---

<BaseLayout
  title={site.name}
  description={site.statement}
  padTop={false}
  jsonLd={jsonLd}
>
  <!-- Hero banner slider (one or more admin-editable banners) -->
  <section
    class="hero-slider relative h-[88svh] min-h-[560px] overflow-hidden"
    aria-roledescription="carousel"
    aria-label="Featured banners"
    data-has-hero
  >
    <div class="hero-track flex h-full w-full" id="hero-track">
      {
        slides.map((slide, i) => (
          <div
            class="hero-slide relative flex h-full w-full flex-shrink-0 items-end"
            aria-roledescription="slide"
            aria-label={`Banner ${i + 1} of ${slides.length}`}
          >
            {slide.image ? (
              <img
                src={slide.image.url}
                alt={slide.heading}
                width={slide.image.width}
                height={slide.image.height}
                loading={i === 0 ? "eager" : "lazy"}
                fetchpriority={i === 0 ? "high" : "auto"}
                class="absolute inset-0 h-full w-full object-cover"
              />
            ) : (
              <Image
                src={heroImg}
                alt={slide.heading}
                widths={[640, 1024, 1600, 2400]}
                sizes="100vw"
                loading={i === 0 ? "eager" : "lazy"}
                fetchpriority={i === 0 ? "high" : undefined}
                class="absolute inset-0 h-full w-full object-cover"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[#150b10]/85 via-[#150b10]/30 to-[#150b10]/50" />
            <div class="container-page relative pb-16 md:pb-24">
              <div class="hero-copy">
                <p class="eyebrow">Fine jewellery · India</p>
                <h1 class="mt-4 max-w-2xl font-serif text-4xl leading-[1.08] md:text-6xl">
                  <span class="text-metallic">{slide.heading}</span>
                </h1>
                {slide.subtext && (
                  <p class="mt-5 max-w-md text-charcoal/85">{slide.subtext}</p>
                )}
                <div class="mt-8 flex flex-wrap gap-4">
                  <a href={slide.buttonLink} class="btn btn-primary">
                    {slide.buttonLabel}
                  </a>
                  {slide.secondaryLabel && (
                    <a href={slide.secondaryLink} class="btn btn-outline">
                      {slide.secondaryLabel}
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      multiple && (
        <>
          <button type="button" class="hero-arrow hero-prev" aria-label="Previous banner">
            ‹
          </button>
          <button type="button" class="hero-arrow hero-next" aria-label="Next banner">
            ›
          </button>
          <div class="hero-dots" aria-label="Choose banner">
            {slides.map((_, i) => (
              <button
                type="button"
                class="hero-dot"
                data-dot={i}
                aria-label={`Go to banner ${i + 1}`}
              />
            ))}
          </div>
        </>
      )
    }
  </section>

  <!-- Brand statement -->
  <section class="container-page py-24 text-center md:py-32">
    <p class="eyebrow">The Livira way</p>
    <p
      class="mx-auto mt-6 max-w-3xl font-serif text-2xl leading-relaxed text-charcoal md:text-[2rem]"
    >
      {site.statement}
    </p>
    <div class="divider-gem mt-10" aria-hidden="true">◆</div>
  </section>

  <!-- Featured grid -->
  <section class="container-page">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <p class="eyebrow">Curated</p>
        <h2 class="mt-2 font-serif text-3xl md:text-4xl">Pieces we love</h2>
      </div>
      <a href="/shop" class="link-underline hidden text-sm uppercase tracking-[0.14em] md:inline"
        >View all</a
      >
    </div>
    <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 md:gap-x-8">
      {featuredGrid.map((entry, i) => <ProductCard entry={entry} priority={i < 3} />)}
    </div>
    <div class="mt-10 text-center md:hidden">
      <a href="/shop" class="btn btn-outline">View all</a>
    </div>
  </section>

  <!-- Categories -->
  <section class="container-page py-24 md:py-32">
    <div class="mb-10 text-center">
      <p class="eyebrow">Shop by</p>
      <h2 class="mt-2 font-serif text-3xl md:text-4xl">Collections</h2>
    </div>
    <div class="cat-grid">
      {
        categories.map((cat) => (
          <a
            href={`/shop?category=${encodeURIComponent(cat)}`}
            class="group relative flex aspect-square items-center justify-center border hairline bg-bone/50 px-3 text-center transition-colors hover:bg-bone"
          >
            <span class="font-serif text-xl tracking-wide md:text-2xl">{cat}</span>
            <span class="absolute bottom-4 text-[11px] uppercase tracking-[0.16em] text-champagne opacity-0 transition-opacity group-hover:opacity-100">
              Explore →
            </span>
          </a>
        ))
      }
      <a
        href={`/shop?category=${encodeURIComponent("Anti-Tarnish Jewels")}`}
        class="group relative flex aspect-square items-center justify-center border hairline bg-bone/50 px-3 text-center transition-colors hover:bg-bone"
      >
        <span class="font-serif text-lg leading-tight tracking-wide md:text-xl">
          Anti-Tarnish<br />Jewels
        </span>
        <span class="absolute bottom-4 text-[11px] uppercase tracking-[0.16em] text-champagne opacity-0 transition-opacity group-hover:opacity-100">
          Explore →
        </span>
      </a>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y hairline bg-bone/50">
    <div class="container-page grid gap-8 py-14 text-center md:grid-cols-3">
      {
        [
          ["Handcrafted", "Made in small batches by hand in India."],
          ["Hallmarked metals", "Recycled gold & sterling silver, certified."],
          ["14-day returns", "Easy returns on unworn pieces."],
        ].map(([t, d]) => (
          <div>
            <h3 class="font-serif text-xl">{t}</h3>
            <p class="mx-auto mt-2 max-w-xs text-sm text-charcoal/65">{d}</p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  /* Collections tiles: two-up on mobile, one flexible row on wider screens
     (so extra tiles like "Anti-Tarnish Jewels" sit beside the others). */
  .cat-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  @media (min-width: 768px) {
    .cat-grid {
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    }
  }

  /* Sliding banner carousel — the track shifts one full width per slide. */
  .hero-track {
    transition: transform 0.7s var(--ease-soft);
    will-change: transform;
  }

  /* Text reveals only for the slide currently on screen. */
  .hero-copy > * {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.7s var(--ease-soft),
      transform 0.7s var(--ease-soft);
  }
  .hero-slide.is-active .hero-copy > * {
    opacity: 1;
    transform: none;
  }
  .hero-copy > *:nth-child(2) {
    transition-delay: 0.08s;
  }
  .hero-copy > *:nth-child(3) {
    transition-delay: 0.16s;
  }
  .hero-copy > *:nth-child(4) {
    transition-delay: 0.24s;
  }

  .hero-arrow {
    position: absolute;
    top: 50%;
    z-index: 10;
    transform: translateY(-50%);
    display: flex;
    height: 46px;
    width: 46px;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--color-champagne) 32%, transparent);
    border-radius: 999px;
    background: rgba(21, 11, 16, 0.32);
    color: var(--color-champagne-soft);
    font-size: 24px;
    line-height: 1;
    backdrop-filter: blur(4px);
    cursor: pointer;
    transition:
      background-color 0.3s var(--ease-soft),
      color 0.3s var(--ease-soft);
  }
  .hero-arrow:hover {
    background: var(--color-champagne);
    color: #241318;
  }
  .hero-prev {
    left: 16px;
  }
  .hero-next {
    right: 16px;
  }
  @media (max-width: 767px) {
    .hero-arrow {
      display: none;
    }
  }

  .hero-dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    z-index: 10;
    display: flex;
    transform: translateX(-50%);
    gap: 10px;
  }
  .hero-dot {
    height: 9px;
    width: 9px;
    border: 0;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-champagne-soft) 34%, transparent);
    cursor: pointer;
    transition:
      width 0.3s var(--ease-soft),
      background-color 0.3s var(--ease-soft);
  }
  .hero-dot.is-active {
    width: 26px;
    background: var(--color-champagne-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-track {
      transition: none;
    }
    .hero-copy > * {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Auto-advancing banner carousel. Falls back to a static first slide when
  // there is only one banner or the visitor prefers reduced motion.
  const root = document.querySelector<HTMLElement>(".hero-slider");
  if (root) {
    const track = root.querySelector<HTMLElement>(".hero-track");
    const slides = [...root.querySelectorAll<HTMLElement>(".hero-slide")];
    const dots = [...root.querySelectorAll<HTMLElement>(".hero-dot")];
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      if (track) track.style.transform = `translateX(-${i * 100}%)`;
      slides.forEach((s, k) => s.classList.toggle("is-active", k === i));
      dots.forEach((d, k) => d.classList.toggle("is-active", k === i));
    };

    const stop = () => {
      if (timer) clearInterval(timer);
      timer = undefined;
    };
    const start = () => {
      if (reduce || slides.length < 2) return;
      stop();
      timer = setInterval(() => show(i + 1), 6000);
    };

    root.querySelector(".hero-next")?.addEventListener("click", () => {
      show(i + 1);
      start();
    });
    root.querySelector(".hero-prev")?.addEventListener("click", () => {
      show(i - 1);
      start();
    });
    dots.forEach((d, k) =>
      d.addEventListener("click", () => {
        show(k);
        start();
      }),
    );
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);

    show(0);
    start();
  }
</script>
