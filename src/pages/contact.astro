---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config";

const waDigits = site.whatsapp.replace(/\D/g, "");
const waMessage = encodeURIComponent(
  `Hi ${site.name}, I'd like to ask about a piece.`,
);
---

<BaseLayout
  title="Contact"
  description={`Get in touch with ${site.name} via WhatsApp or email.`}
>
  <section class="container-page py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">We'd love to hear from you</p>
      <h1 class="mt-3 font-serif text-4xl md:text-5xl">Get in touch</h1>
      <p class="mt-5 text-charcoal/70">
        Questions about a piece, sizing, custom orders or an existing order?
        Message us — we usually reply within a day.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        <a
          href={`https://wa.me/${waDigits}?text=${waMessage}`}
          target="_blank"
          rel="noopener"
          class="group flex flex-col items-center gap-3 border hairline p-8 transition-colors hover:bg-bone/60"
        >
          <span class="font-serif text-xl">WhatsApp</span>
          <span class="text-sm text-charcoal/60">{site.whatsapp}</span>
          <span class="text-xs uppercase tracking-[0.14em] text-champagne">
            Chat with us →
          </span>
        </a>
        <a
          href={`mailto:${site.supportEmail}`}
          class="group flex flex-col items-center gap-3 border hairline p-8 transition-colors hover:bg-bone/60"
        >
          <span class="font-serif text-xl">Email</span>
          <span class="text-sm text-charcoal/60">{site.supportEmail}</span>
          <span class="text-xs uppercase tracking-[0.14em] text-champagne">
            Write to us →
          </span>
        </a>
      </div>

      {
        site.instagram && (
          <p class="mt-10 text-sm text-charcoal/60">
            Or follow along on{" "}
            <a
              href={`https://instagram.com/${site.instagram}`}
              target="_blank"
              rel="noopener"
              class="link-underline text-champagne"
            >
              @{site.instagram}
            </a>
          </p>
        )
      }
    </div>
  </section>
</BaseLayout>
