---
import { getCollection, getEntry } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Gallery from "../../components/Gallery.astro";
import ProductCard from "../../components/ProductCard.astro";
import AddToBag from "../../components/react/AddToBag.tsx";
import { formatINR } from "../../lib/format";
import { site } from "../../config";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({ params: { slug: entry.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry("products", slug!);
if (!entry) return Astro.redirect("/404");
const p = entry.data;

// Small optimised thumbnail URL for the cart line (string, not <Image>).
// Falls back to the brand OG image when a product has no photos yet.
const primary = p.images[0];
const thumb = primary
  ? await getImage({
      src: primary.url,
      width: 144,
      height: 180,
      format: "webp",
    })
  : { src: "/og-default.jpg" };

// OG image (absolute URL) for this product.
const og = primary
  ? await getImage({ src: primary.url, width: 1200, height: 1500 })
  : { src: "/og-default.jpg" };

const onSale = p.compareAtPrice && p.compareAtPrice > p.price;
const paragraphs = p.description.split(/\n\s*\n/).filter(Boolean);

const related = (await getCollection("products"))
  .filter((e) => e.id !== entry.id && e.data.category === p.category)
  .slice(0, 4);
const fill =
  related.length >= 4
    ? related
    : [
        ...related,
        ...(await getCollection("products")).filter(
          (e) => e.id !== entry.id && e.data.category !== p.category,
        ),
      ].slice(0, 4);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: p.name,
  image: new URL(og.src, Astro.site).href,
  description: p.description.replace(/\n+/g, " ").slice(0, 300),
  sku: p.sku ?? undefined,
  category: p.category,
  brand: { "@type": "Brand", name: site.name },
  offers: {
    "@type": "Offer",
    priceCurrency: "INR",
    price: p.price,
    availability: p.inStock
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
    url: new URL(`/product/${entry.id}`, Astro.site).href,
  },
};
---

<BaseLayout
  title={p.name}
  description={paragraphs[0] ?? p.material}
  image={og.src}
  type="product"
  jsonLd={jsonLd}
>
  <section class="container-page py-10 md:py-14">
    <nav class="mb-8 text-xs uppercase tracking-[0.12em] text-charcoal/50">
      <a href="/shop" class="link-underline">Shop</a>
      <span class="px-2">/</span>
      <a href={`/shop?category=${p.category}`} class="link-underline">{p.category}</a>
    </nav>

    <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
      <Gallery images={p.images} name={p.name} />

      <div class="lg:pt-4">
        <p class="eyebrow flex items-center gap-2">
          <span class="gem-mark">◆</span> {p.category}
        </p>
        <h1 class="mt-3 font-serif text-3xl leading-tight md:text-4xl">{p.name}</h1>

        <div class="mt-3 h-px w-16 gold-rule" aria-hidden="true"></div>

        <div class="mt-5 flex items-baseline gap-3">
          <span class="text-2xl text-champagne">{formatINR(p.price)}</span>
          {
            onSale && (
              <span class="text-lg text-charcoal/40 line-through">
                {formatINR(p.compareAtPrice!)}
              </span>
            )
          }
        </div>
        {
          site.showGstNote && (
            <p class="mt-1 text-xs text-charcoal/50">{site.gstNote}</p>
          )
        }

        <div class="mt-8 space-y-4 text-[0.97rem] leading-relaxed text-charcoal/80">
          {paragraphs.map((para) => <p>{para}</p>)}
        </div>

        <div class="mt-8">
          <AddToBag
            client:visible
            inStock={p.inStock}
            product={{
              slug: entry.id,
              name: p.name,
              price: p.price,
              image: thumb.src,
            }}
          />
          {
            !p.inStock && (
              <p class="mt-3 text-sm text-charcoal/55">
                This piece is currently sold out. {" "}
                <a href="/contact" class="link-underline text-champagne">
                  Ask about a waitlist
                </a>
                .
              </p>
            )
          }
        </div>

        <!-- Specifications -->
        <dl class="mt-10 divide-y divide-charcoal/10 border-y hairline text-sm">
          {
            [
              ["Material", p.material],
              p.weightGrams ? ["Weight", `${p.weightGrams} g`] : null,
              p.dimensions ? ["Dimensions", p.dimensions] : null,
              p.sku ? ["SKU", p.sku] : null,
            ]
              .filter((row): row is [string, string] => row !== null)
              .map(([label, value]) => (
                <div class="flex justify-between gap-6 py-3">
                  <dt class="text-charcoal/55">{label}</dt>
                  <dd class="text-right text-charcoal/85">{value}</dd>
                </div>
              ))
          }
        </dl>

        <div class="mt-10 grid grid-cols-3 gap-4 border-t hairline pt-8 text-center">
          {
            [
              {
                label: `Free shipping over ${formatINR(site.freeShippingThreshold)}`,
                svg: `<path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.6" fill="none" stroke="currentColor" stroke-width="1.2"/><circle cx="17.5" cy="17" r="1.6" fill="none" stroke="currentColor" stroke-width="1.2"/>`,
              },
              {
                label: "Hallmarked metals",
                svg: `<circle cx="12" cy="10" r="6" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M9 15.5 8 22l4-2 4 2-1-6.5" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>`,
              },
              {
                label: "14-day returns",
                svg: `<path d="M4 12a8 8 0 1 1 2.5 5.8" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M4 8v4h4" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
              },
            ].map((f) => (
              <div class="flex flex-col items-center gap-2">
                <span class="text-champagne" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" set:html={f.svg} />
                </span>
                <span class="text-[10px] uppercase leading-tight tracking-[0.1em] text-charcoal/60">
                  {f.label}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  {
    fill.length > 0 && (
      <section class="container-page py-20">
        <div class="mb-12 text-center">
          <p class="eyebrow flex items-center justify-center gap-2">
            <span class="gem-mark">◆</span> Pairs beautifully
          </p>
          <h2 class="mt-2 font-serif text-2xl md:text-3xl">You may also like</h2>
        </div>
        <div class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-4 md:gap-x-8">
          {fill.map((e) => (
            <ProductCard entry={e} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
