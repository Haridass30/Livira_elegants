---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../config";

const waDigits = site.whatsapp.replace(/\D/g, "");
---

<BaseLayout title="Order confirmed" description="Thank you for your order." noindex>
  <section class="container-page py-24 md:py-32">
    <div class="mx-auto max-w-xl text-center">
      <div
        class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border-2 border-champagne text-champagne"
      >
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M5 13l4 4L19 7"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <p class="eyebrow mt-8">Thank you</p>
      <h1 class="mt-3 font-serif text-4xl md:text-5xl">Your order is confirmed</h1>

      <p class="mt-5 text-charcoal/70">
        We've received your order and emailed your details. Your reference is:
      </p>
      <p
        id="order-ref"
        class="mt-3 inline-block border hairline bg-bone/50 px-5 py-2 font-serif text-xl tracking-wide"
      >
        —
      </p>

      <p class="mt-8 text-sm leading-relaxed text-charcoal/65">
        Keep this reference for any questions about your order. We'll be in touch
        with shipping updates. Need help?{" "}
        <a
          href={`https://wa.me/${waDigits}`}
          target="_blank"
          rel="noopener"
          class="link-underline text-champagne">Message us on WhatsApp</a
        >.
      </p>

      <div class="mt-10">
        <a href="/shop" class="btn btn-primary">Continue shopping</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // The order reference is passed via ?ref= from the checkout island.
  const ref = new URLSearchParams(location.search).get("ref");
  const el = document.getElementById("order-ref");
  if (el && ref) el.textContent = ref;
  else if (el) el.textContent = "your emailed confirmation";
</script>
