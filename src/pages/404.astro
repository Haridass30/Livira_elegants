---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" noindex>
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <p class="eyebrow">404</p>
    <h1 class="mt-3 font-serif text-5xl md:text-6xl">Lost its sparkle</h1>
    <p class="mt-4 max-w-md text-charcoal/65">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="mt-8 flex gap-4">
      <a href="/" class="btn btn-outline">Home</a>
      <a href="/shop" class="btn btn-primary">Shop the collection</a>
    </div>
  </section>
</BaseLayout>
