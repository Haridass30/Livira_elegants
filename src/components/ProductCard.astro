---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { formatINR } from "../lib/format";

interface Props {
  entry: CollectionEntry<"products">;
  /** Eager-load the first row above the fold; lazy-load the rest. */
  priority?: boolean;
  class?: string;
}

const { entry, priority = false, class: className = "" } = Astro.props;
const p = entry.data;
const onSale = p.compareAtPrice && p.compareAtPrice > p.price;
const discount = onSale
  ? Math.round(((p.compareAtPrice! - p.price) / p.compareAtPrice!) * 100)
  : 0;
// A second photo lets the card cross-fade on hover — a boutique touch.
const hover = p.images[1];
---

<a
  href={`/product/${entry.id}`}
  class:list={["group block", className]}
  aria-label={`${p.name}, ${formatINR(p.price)}`}
>
  <div class="card-lux relative overflow-hidden rounded-[3px]" style="aspect-ratio: 4 / 5;">
    {
      p.images[0] && (
        <Image
          src={p.images[0].url}
          width={p.images[0].width}
          height={p.images[0].height}
          alt={p.name}
          widths={[280, 420, 640, 900]}
          sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 90vw"
          loading={priority ? "eager" : "lazy"}
          fetchpriority={priority ? "high" : "auto"}
          class:list={[
            "h-full w-full object-cover transition-all duration-[900ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.05]",
            hover && "group-hover:opacity-0",
          ]}
        />
      )
    }
    {
      hover && (
        <Image
          src={hover.url}
          width={hover.width}
          height={hover.height}
          alt=""
          aria-hidden="true"
          widths={[280, 420, 640, 900]}
          sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 90vw"
          loading="lazy"
          class="absolute inset-0 h-full w-full scale-[1.05] object-cover opacity-0 transition-opacity duration-[900ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:opacity-100"
        />
      )
    }

    <!-- Badges -->
    {
      onSale && p.inStock && (
        <span class="pill absolute left-3 top-3">−{discount}%</span>
      )
    }
    {
      !p.inStock && (
        <span class="pill absolute left-3 top-3 !text-charcoal/80">Sold out</span>
      )
    }

    <!-- Hover affordance -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 flex justify-center bg-gradient-to-t from-[#150b10]/75 to-transparent pb-4 pt-10 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
      <span class="text-[11px] uppercase tracking-[0.22em] text-champagne-soft">
        View piece →
      </span>
    </div>
  </div>

  <div class="pt-4 text-center">
    <p class="text-[10px] uppercase tracking-[0.2em] text-champagne/70">
      {p.category}
    </p>
    <h3 class="mt-1.5 font-serif text-lg leading-snug transition-colors group-hover:text-ink">
      {p.name}
    </h3>
    <p class="mt-1.5 flex items-baseline justify-center gap-2 text-sm">
      <span class="text-champagne">{formatINR(p.price)}</span>
      {
        onSale && (
          <span class="text-charcoal/40 line-through">
            {formatINR(p.compareAtPrice!)}
          </span>
        )
      }
    </p>
  </div>
</a>
