---
// Self-hosted variable fonts (Fontsource) — only the weights we use.
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "../styles/global.css";

import Seo from "../components/Seo.astro";
import AnnouncementBar from "../components/AnnouncementBar.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CartDrawer from "../components/react/CartDrawer.tsx";
import { getSiteContent } from "../lib/siteContent";

const hasBar = (await getSiteContent()).announcements.length > 0;

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article" | "product";
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
  /** Set false on the homepage where the hero owns the top of the page. */
  padTop?: boolean;
}

const { padTop = true, ...seo } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1d1116" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Seo {...seo} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-charcoal focus:text-ivory focus:px-4 focus:py-2"
      >Skip to content</a
    >
    <AnnouncementBar />
    <Header />
    <main
      id="main"
      class:list={[
        padTop && (hasBar ? "pt-[6.25rem] md:pt-[7.25rem]" : "pt-20 md:pt-24"),
        !padTop && hasBar && "pt-9",
      ]}
    >
      <slot />
    </main>
    <Footer />

    <!-- Cart slide-over: the only always-mounted island (shares the cart store). -->
    <CartDrawer client:idle />
  </body>
</html>
